{
  "$schema": "https://encore.dev/schemas/infra.schema.json",
  "metadata": {
    "app_id": "skyforge",
    "env_name": "production",
    "env_type": "production",
    "cloud": "local",
    "base_url": "http://skyforge-server:8085"
  },
  "service_discovery": {
    "frontend": {
      "base_url": "http://skyforge-server:8085"
    },
    "authn": {
      "base_url": "http://skyforge-server:8085"
    },
    "forwardregistry": {
      "base_url": "http://skyforge-server:8085"
    },
    "forwardtenant": {
      "base_url": "http://skyforge-server:8085"
    },
    "gitcredentials": {
      "base_url": "http://skyforge-server:8085"
    },
    "servicenow": {
      "base_url": "http://skyforge-server:8085"
    },
    "settings": {
      "base_url": "http://skyforge-server:8085"
    },
    "platform": {
      "base_url": "http://skyforge-server:8085"
    },
    "configchanges": {
      "base_url": "http://skyforge-server:8085"
    },
    "teams": {
      "base_url": "http://skyforge-server:8085"
    },
    "skyforge": {
      "base_url": "http://skyforge-server:8085"
    }
  },
  "sql_servers": [
    {
      "host": "db:5432",
      "databases": {
        "skyforge_server": {
          "username": "skyforge_server",
          "password": {
            "$env": "SKYFORGE_DB_PASSWORD"
          },
          "max_connections": 50,
          "min_connections": 5
        }
      }
    }
  ],
  "object_storage": [
    {
      "type": "s3",
      "region": "us-east-1",
      "endpoint": "http://s3gw:7480",
      "access_key_id": "skyforge",
      "secret_access_key": "skyforge",
      "buckets": {
        "skyforge": {
          "name": "skyforge-files",
          "public_base_url": "http://s3gw:7480/skyforge-files"
        }
      }
    }
  ],
  "pubsub": [
    {
      "type": "nsq",
      "hosts": "nsq:4150",
      "topics": {
        "skyforge-task-cancel": {
          "name": "skyforge-task-cancel"
        },
        "skyforge-task-queue-interactive": {
          "name": "skyforge-task-queue-interactive"
        },
        "skyforge-task-queue-background": {
          "name": "skyforge-task-queue-background"
        },
        "skyforge-task-status": {
          "name": "skyforge-task-status",
          "subscriptions": {
            "skyforge-task-status-handler": {
              "name": "skyforge-task-status-handler"
            }
          }
        },
        "skyforge-maintenance": {
          "name": "skyforge-maintenance"
        }
      }
    }
  ],
  "redis": {
    "default": {
      "host": "redis:6379",
      "database_index": 0,
      "key_prefix": "skyforge"
    }
  },
  "graceful_shutdown": {
    "total": 30,
    "shutdown_hooks": 10,
    "handlers": 20
  },
  "secrets": {
    "SKYFORGE_SESSION_SECRET": {
      "$env": "SKYFORGE_SESSION_SECRET"
    },
    "SKYFORGE_ADMIN_PASSWORD": {
      "$env": "SKYFORGE_ADMIN_PASSWORD"
    },
    "SKYFORGE_OIDC_CLIENT_ID": {
      "$env": "SKYFORGE_OIDC_CLIENT_ID"
    },
    "SKYFORGE_OIDC_CLIENT_SECRET": {
      "$env": "SKYFORGE_OIDC_CLIENT_SECRET"
    },
    "SKYFORGE_DB_PASSWORD": {
      "$env": "SKYFORGE_DB_PASSWORD"
    },
    "SKYFORGE_GITEA_PASSWORD": {
      "$env": "SKYFORGE_GITEA_PASSWORD"
    },
    "SKYFORGE_OBJECT_STORAGE_ROOT_USER": {
      "$env": "SKYFORGE_OBJECT_STORAGE_ROOT_USER"
    },
    "SKYFORGE_OBJECT_STORAGE_ROOT_PASSWORD": {
      "$env": "SKYFORGE_OBJECT_STORAGE_ROOT_PASSWORD"
    },
    "SKYFORGE_OBJECT_STORAGE_ACCESS_KEY": {
      "$env": "SKYFORGE_OBJECT_STORAGE_ACCESS_KEY"
    },
    "SKYFORGE_OBJECT_STORAGE_SECRET_KEY": {
      "$env": "SKYFORGE_OBJECT_STORAGE_SECRET_KEY"
    },
    "SKYFORGE_QUICK_DEPLOY_FORWARD_USERNAME": {
      "$env": "SKYFORGE_QUICK_DEPLOY_FORWARD_USERNAME"
    },
    "SKYFORGE_QUICK_DEPLOY_FORWARD_PASSWORD": {
      "$env": "SKYFORGE_QUICK_DEPLOY_FORWARD_PASSWORD"
    },
    "SKYFORGE_INTERNAL_TOKEN": {
      "$env": "SKYFORGE_INTERNAL_TOKEN"
    },
    "YAADE_ADMIN_PASSWORD": {
      "$env": "YAADE_ADMIN_PASSWORD"
    },
    "SKYFORGE_SROS_LICENSE_B64": {
      "$env": "SKYFORGE_SROS_LICENSE_B64"
    },
    "SKYFORGE_AWS_ACCESS_KEY_ID": {
      "$env": "SKYFORGE_AWS_ACCESS_KEY_ID"
    },
    "SKYFORGE_AWS_SECRET_ACCESS_KEY": {
      "$env": "SKYFORGE_AWS_SECRET_ACCESS_KEY"
    },
    "SKYFORGE_AZURE_TENANT_ID": {
      "$env": "SKYFORGE_AZURE_TENANT_ID"
    },
    "SKYFORGE_AZURE_CLIENT_ID": {
      "$env": "SKYFORGE_AZURE_CLIENT_ID"
    },
    "SKYFORGE_AZURE_CLIENT_SECRET": {
      "$env": "SKYFORGE_AZURE_CLIENT_SECRET"
    },
    "SKYFORGE_GCP_SERVICE_ACCOUNT_JSON": {
      "$env": "SKYFORGE_GCP_SERVICE_ACCOUNT_JSON"
    },
    "SKYFORGE_HETZNER_API_TOKEN": {
      "$env": "SKYFORGE_HETZNER_API_TOKEN"
    },
    "SKYFORGE_HETZNER_WIREGUARD_HUB_PUBLIC_KEY": {
      "$env": "SKYFORGE_HETZNER_WIREGUARD_HUB_PUBLIC_KEY"
    },
    "SKYFORGE_HETZNER_K3S_TOKEN": {
      "$env": "SKYFORGE_HETZNER_K3S_TOKEN"
    }
  },
  "env": {
    "SKYFORGE_DB_HOST": "db",
    "SKYFORGE_DB_PORT": "5432",
    "SKYFORGE_DB_NAME": "skyforge_server",
    "SKYFORGE_DB_USER": "skyforge_server",
    "SKYFORGE_DB_SSLMODE": "disable",
    "SKYFORGE_OBJECT_STORAGE_ENDPOINT": "s3gw:7480",
    "SKYFORGE_OBJECT_STORAGE_USE_SSL": "false",
    "APP_VERSION": "${APP_VERSION}",
    "BUILD_TIME": "${BUILD_TIME}",
    "UI_VERSION": "${UI_VERSION}"
  }
}
